{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Wails App",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}",
      "cwd": "${workspaceFolder}",
      "env": {
        "WAILS_DEV": "true"
      },
      "buildFlags": "-tags=dev -gcflags=all='-N -l'"
    }
  ]
}
